	"semanticHighlighting": true,
	"semanticTokenColors": {
		"enumMember": {
			"foreground": "#ffd400"
		},
		"variable.constant": {
			"foreground": "#f78c6c"
		},
		"variable.defaultLibrary": {
			"foreground": "#ff2cf1"
		}
	},
	"tokenColors": [
		{
			// Muted blue, italic — fades into background without stealing attention
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.quoted.docstring.multi.python"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#0098df"
			}
		},
		{
			// Default text — crisp near-white
			"name": "Variables",
			"scope": [
				"variable"
			],
			"settings": {
				"foreground": "#fdfeff"
			}
		},
		{
			// Other/property variables — hot pink (e.g. obj.prop, this.x)
			"name": "Variable Other",
			"scope": [
				"variable.other",
				"variable.other.object.js",
				"variable.other.object.jsx",
				"variable.object.property.js",
				"variable.object.property.jsx"
			],
			"settings": {
				"foreground": "#ff2e97"
			}
		},
		{
			// language keywords: this, self, super → pink
			"name": "Variable Language",
			"scope": [
				"variable.language",
				"entity.name.type.class.js",
				"entity.name.type.class.ts",
				"entity.name.type.class.tsx"
			],
			"settings": {
				"foreground": "#ff2e97"
			}
		},
		{
			"name": "Colors",
			"scope": [
				"constant.other.color"
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			// Errors — deep crimson pink
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#9e0a52"
			}
		},
		{
			// Invalid deprecated
			"name": "Invalid Deprecated",
			"scope": [
				"invalid.deprecated"
			],
			"settings": {
				"foreground": "#00d7e2"
			}
		},
		{
			// Keywords (if, else, return, import, export) — hot magenta-pink
			"name": "Keyword",
			"scope": [
				"keyword"
			],
			"settings": {
				"foreground": "#ff2cf1"
			}
		},
		{
			// Control flow bold
			"name": "Keyword Control",
			"scope": [
				"keyword.control"
			],
			"settings": {
				"foreground": "#ff2cf1",
				"fontStyle": "bold"
			}
		},
		{
			// Misc keywords (unit, use-as, new, etc.) — vivid purple
			"name": "Keyword Other",
			"scope": [
				"keyword.other",
				"keyword.other.use",
				"keyword.other.function.use",
				"keyword.other.namespace",
				"keyword.other.new",
				"keyword.other.special-method",
				"keyword.other.unit",
				"keyword.other.use-as"
			],
			"settings": {
				"foreground": "#a83dff"
			}
		},
		{
			// Storage modifiers (public, static, async) — cornflower blue
			"name": "Storage",
			"scope": [
				"storage",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#40a9ff"
			}
		},
		{
			// Storage types (class, function, var, const, let) — vibrant magenta
			"name": "Storage Type",
			"scope": [
				"storage.type"
			],
			"settings": {
				"foreground": "#ff1bf0",
				"fontStyle": ""
			}
		},
		{
			// JS/TS: function keyword specifically → keep magenta
			"name": "JAVASCRIPT Storage Type Function",
			"scope": [
				"source.js storage.type.function",
				"source.ts storage"
			],
			"settings": {
				"foreground": "#ff25f0"
			}
		},
		{
			// Operators and general punctuation — muted medium blue
			"name": "Operator, Punctuation Misc",
			"scope": [
				"constant.other.color",
				"punctuation",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.definition.tag.html",
				"punctuation.definition.tag.begin.html",
				"punctuation.separator.inheritance.php",
				"punctuation.definition.tag.end.html",
				"punctuation.section.embedded",
				"keyword.other.template",
				"keyword.other.substitution"
			],
			"settings": {
				"foreground": "#44a1fd"
			}
		},
		{
			// Function params punctuation — bright yellow
			"name": "Punctuation Parameters",
			"scope": [
				"punctuation.definition.parameters"
			],
			"settings": {
				"foreground": "#ffee80"
			}
		},
		{
			// Template expression punctuation — bright yellow
			"name": "Punctuation Template Expression",
			"scope": [
				"punctuation.definition.template-expression",
				"meta.template.expression"
			],
			"settings": {
				"foreground": "#18b6ff"
			}
		},
		{
			// HTML/JSX Tags — hot pink, unmistakable
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"meta.tag.sgml"
			],
			"settings": {
				"foreground": "#ff2e97"
			}
		},
		{
			// Tag attributes — golden yellow (stands out against pink tags)
			"name": "Tag Attribute",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#ffd400"
			}
		},
		{
			// HTML-specific attributes — also golden yellow
			"name": "HTML Attributes",
			"scope": [
				"text.html.basic entity.other.attribute-name.html",
				"text.html.basic entity.other.attribute-name"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#ffd400"
			}
		},
		{
			// Function definitions — bright sky blue (clear, cool contrast)
			"name": "Function Name",
			"scope": [
				"entity.name.function - meta.function-call",
				"entity.name.function",
				"variable.function"
			],
			"settings": {
				"foreground": "#39c0ff"
			}
		},
		{
			// Library/support functions — golden yellow
			"name": "Library Function",
			"scope": [
				"support.function"
			],
			"settings": {
				"foreground": "#ffd400"
			}
		},
		{
			// Function calls — slightly different cyan
			"name": "Function Call",
			"scope": [
				"meta.function-call"
			],
			"settings": {
				"foreground": "#2fb3ff"
			}
		},
		{
			// Function arguments / parameters — hot pink
			"name": "Function Argument / Parameter",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#ff2e97"
			}
		},
		{
			// Class names — hot pink (classes are important landmarks)
			"name": "Class Name",
			"scope": [
				"entity.name.class",
				"entity.name.type.class"
			],
			"settings": {
				"foreground": "#ff2e97",
				"fontStyle": ""
			}
		},
		{
			// General entity names — golden yellow
			"name": "Entity",
			"scope": [
				"entity.name"
			],
			"settings": {
				"foreground": "#ffd400"
			}
		},
		{
			// Inherited class — italic sky blue
			"name": "Inherited Class",
			"scope": [
				"entity.other.inherited-class",
				"meta.other.inherited-class.php",
				"entity.other.inherited-class.js",
				"entity.other.inherited-class.ts",
